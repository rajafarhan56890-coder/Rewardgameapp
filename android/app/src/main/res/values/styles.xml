<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window while the process is starting
         when the Android OS starts the activity. Configure the Window
         background so it matches the dark splash screen for a seamless
         cold-start experience. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>

    <!-- Theme applied to the Android Window as soon as the process has
         started. This theme determines the color of the Android Window
         while your Flutter UI initializes, as well as behind your Flutter
         UI while its running. -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/app_background</item>
    </style>
</resources>
