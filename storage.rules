rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Users may only upload/read/delete their own profile picture, named
    // deterministically as profile_pictures/{uid}.jpg by the app.
    match /profile_pictures/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && fileName == request.auth.uid + '.jpg'
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && fileName == request.auth.uid + '.jpg';
    }

    // Admin-managed static assets (game icons, task icons) — read-only.
    match /app_assets/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
